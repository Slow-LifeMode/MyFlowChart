<UserControl x:Class="MyFlowChart.Controls.FlowChartControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:MyFlowChart.Models"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="650"
             Focusable="True">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <DataTemplate x:Key="FlowNodeTemplate"
                      DataType="{x:Type models:FlowNode}">
            <StackPanel Width="190"
                        AllowDrop="True"
                        Cursor="Arrow"
                        DragOver="Node_DragOver"
                        Drop="Node_Drop">
                <Border x:Name="NodeBox"
                        Width="190"
                        Height="54"
                        Background="#FFFFFF"
                        BorderBrush="#CBD7D4"
                        BorderThickness="1"
                        CornerRadius="4"
                        SnapsToDevicePixels="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="34" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="58" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="StatusStrip"
                                Background="#38D99A"
                                CornerRadius="4,0,0,4" />

                        <Border Grid.Column="1"
                                Width="24"
                                Height="24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="#EEF4F2"
                                CornerRadius="12">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#51625F"
                                       Text="{Binding Sequence, StringFormat={}{0:00}}" />
                        </Border>

                        <StackPanel Grid.Column="2"
                                    Margin="2,0,8,0"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#22302D"
                                       Text="{Binding DisplayName}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="10"
                                       Foreground="#7A8C88"
                                       Text="{Binding OperatorName}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <StackPanel Grid.Column="3"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center">
                            <Border x:Name="StatusPill"
                                    Height="20"
                                    Background="#EEF2F1"
                                    CornerRadius="10">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="10"
                                           Foreground="#51625F"
                                           Text="{Binding StatusText}" />
                            </Border>
                            <TextBlock Margin="0,3,0,0"
                                       HorizontalAlignment="Center"
                                       FontSize="9"
                                       Foreground="#8A9B97"
                                       Text="{Binding ElapsedMilliseconds, StringFormat={}{0:0} ms}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid x:Name="ConnectorPanel"
                      Width="190"
                      Height="38">
                    <Line X1="95"
                          Y1="0"
                          X2="95"
                          Y2="29"
                          Stroke="#AFC0BC"
                          StrokeThickness="2" />
                    <Path Width="14"
                          Height="8"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Bottom"
                          Data="M 0 0 L 7 8 L 14 0 Z"
                          Fill="#AFC0BC"
                          Stretch="Fill" />
                </Grid>
            </StackPanel>

            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsLast}"
                             Value="True">
                    <Setter TargetName="ConnectorPanel"
                            Property="Visibility"
                            Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}"
                             Value="{x:Static models:FlowNodeStatus.Running}">
                    <Setter TargetName="NodeBox"
                            Property="BorderBrush"
                            Value="#3D7DFF" />
                    <Setter TargetName="NodeBox"
                            Property="Background"
                            Value="#F2F7FF" />
                    <Setter TargetName="StatusStrip"
                            Property="Background"
                            Value="#3D7DFF" />
                    <Setter TargetName="StatusPill"
                            Property="Background"
                            Value="#DCEAFF" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}"
                             Value="{x:Static models:FlowNodeStatus.OK}">
                    <Setter TargetName="NodeBox"
                            Property="BorderBrush"
                            Value="#38D99A" />
                    <Setter TargetName="StatusStrip"
                            Property="Background"
                            Value="#38D99A" />
                    <Setter TargetName="StatusPill"
                            Property="Background"
                            Value="#DDF8EC" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}"
                             Value="{x:Static models:FlowNodeStatus.NG}">
                    <Setter TargetName="NodeBox"
                            Property="BorderBrush"
                            Value="#E65757" />
                    <Setter TargetName="StatusStrip"
                            Property="Background"
                            Value="#E65757" />
                    <Setter TargetName="StatusPill"
                            Property="Background"
                            Value="#FFE3E3" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}"
                             Value="{x:Static models:FlowNodeStatus.Stopped}">
                    <Setter TargetName="NodeBox"
                            Property="BorderBrush"
                            Value="#E8A438" />
                    <Setter TargetName="StatusStrip"
                            Property="Background"
                            Value="#E8A438" />
                    <Setter TargetName="StatusPill"
                            Property="Background"
                            Value="#FFF0D9" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Grid AllowDrop="True"
          Background="#EEF3F1"
          ClipToBounds="True"
          DragOver="FlowChart_DragOver"
          Drop="FlowChart_Drop">
        <ScrollViewer x:Name="viewScrollViewer"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#F7FAF9"
                      Cursor="Cross"
                      PreviewMouseWheel="View_PreviewMouseWheel"
                      PreviewMouseLeftButtonDown="View_PreviewMouseLeftButtonDown"
                      PreviewMouseMove="View_PreviewMouseMove"
                      PreviewMouseLeftButtonUp="View_PreviewMouseLeftButtonUp"
                      LostMouseCapture="ViewScrollViewer_LostMouseCapture"
                      ScrollChanged="ViewScrollViewer_ScrollChanged"
                      SizeChanged="ViewScrollViewer_SizeChanged">
            <Grid x:Name="flowWorldRoot"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Top">
                <Grid.LayoutTransform>
                    <ScaleTransform x:Name="flowScaleTransform"
                                    ScaleX="1"
                                    ScaleY="1" />
                </Grid.LayoutTransform>

                <Border x:Name="flowScene"
                        Width="224"
                        Height="200"
                        Padding="16"
                        Background="#F8FCFB"
                        BorderBrush="#C9DAD5"
                        BorderThickness="1"
                        SnapsToDevicePixels="True">
                    <Grid x:Name="flowContentHost"
                          Width="190"
                          Height="166">
                        <ItemsControl ItemsSource="{Binding Nodes, ElementName=Root}"
                                      ItemTemplate="{StaticResource FlowNodeTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Top" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="15"
                                   Foreground="#8A9B97"
                                   Text="空流程">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility"
                                            Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasNodes, ElementName=Root}"
                                                     Value="True">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <Border x:Name="miniMap"
                Width="190"
                Height="150"
                Margin="0,0,14,14"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="#FFFFFF"
                BorderBrush="#B8C8C4"
                BorderThickness="1"
                CornerRadius="4"
                MouseLeftButtonDown="MiniMap_MouseLeftButtonDown"
                SnapsToDevicePixels="True">
            <Grid>
                <TextBlock x:Name="zoomText"
                           Margin="8,4,0,0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           FontSize="10"
                           Foreground="#5A6D68"
                           Text="100%" />

                <Grid x:Name="miniMapRoot"
                      Margin="6,22,6,6"
                      Background="#F8FCFB"
                      ClipToBounds="True">
                    <Canvas>
                        <Border x:Name="miniMapScene"
                                Width="224"
                                Height="200"
                                Padding="16"
                                Background="#F8FCFB"
                                BorderBrush="#C9DAD5"
                                BorderThickness="1"
                                IsHitTestVisible="False"
                                SnapsToDevicePixels="True">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="miniMapScaleTransform"
                                                ScaleX="1"
                                                ScaleY="1" />
                            </Border.RenderTransform>
                            <Grid x:Name="miniMapContentHost"
                                  Width="190"
                                  Height="166">
                                <ItemsControl IsHitTestVisible="False"
                                              ItemsSource="{Binding Nodes, ElementName=Root}"
                                              ItemTemplate="{StaticResource FlowNodeTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Top" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>

                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="15"
                                           Foreground="#8A9B97"
                                           Text="空流程">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Visibility"
                                                    Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasNodes, ElementName=Root}"
                                                             Value="True">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </Canvas>

                    <Canvas x:Name="miniMapOverlay"
                            IsHitTestVisible="False">
                        <Rectangle x:Name="miniMapViewport"
                                   Fill="#334E6826"
                                   Stroke="#2D6CDF"
                                   StrokeThickness="1.5" />
                    </Canvas>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
