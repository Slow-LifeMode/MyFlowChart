<Window x:Class="MyFlowChart.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:MyFlowChart.Controls"
        xmlns:models="clr-namespace:MyFlowChart.Models"
        xmlns:openCv="clr-namespace:OpenCvWindowTool;assembly=OpenCvWindowTool"
        xmlns:viewModels="clr-namespace:MyFlowChart.ViewModels"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        mc:Ignorable="d"
        Title="MyFlowChart Demo" Height="620" Width="1180"
        MinHeight="520" MinWidth="960"
        FontFamily="Microsoft YaHei"
        Background="#EEF3F1">
    <Window.DataContext>
        <viewModels:MainWindowViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="ToolButtonStyle"
               TargetType="{x:Type Button}">
            <Setter Property="Width"
                    Value="45" />
            <Setter Property="Height"
                    Value="42" />
            <Setter Property="Margin"
                    Value="0,0,5,0" />
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="FontSize"
                    Value="12" />
        </Style>

        <DataTemplate DataType="{x:Type models:LineFindOperatorParameters}">
            <Border Margin="0,10,0,0"
                    Padding="10"
                    Background="#FFFFFF"
                    BorderBrush="#D5DCE0"
                    BorderThickness="1"
                    CornerRadius="4">
                <StackPanel>
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Text="直线查找参数" />

                     <UniformGrid Margin="0,10,0,0"
                                  Columns="2">
                        <TextBlock Margin="0,0,8,6"
                                   VerticalAlignment="Center"
                                   Text="检测模式" />
                        <ComboBox Height="28"
                                  Margin="0,0,0,6"
                                  SelectedValue="{Binding DetectionMode, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="SelfMode"
                                          Tag="{x:Static openCv:LineDetectionMode.SelfMode}" />
                            <ComboBoxItem Content="OPTMode"
                                          Tag="{x:Static openCv:LineDetectionMode.OPTMode}" />
                        </ComboBox>

                        <TextBlock Margin="0,0,8,6"
                                   VerticalAlignment="Center"
                                   Text="边缘阈值" />
                        <TextBox Height="28"
                                 Margin="0,0,0,6"
                                 Text="{Binding EdgeThreshold, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,0,8,6"
                                   VerticalAlignment="Center"
                                   Text="扫描线数" />
                        <TextBox Height="28"
                                 Margin="0,0,0,6"
                                 Text="{Binding SampleCount, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,0,8,6"
                                   VerticalAlignment="Center"
                                   Text="采样步长" />
                        <TextBox Height="28"
                                 Margin="0,0,0,6"
                                 Text="{Binding SampleStep, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,0,8,6"
                                   VerticalAlignment="Center"
                                   Text="边缘宽度" />
                        <TextBox Height="28"
                                 Margin="0,0,0,6"
                                 Text="{Binding EdgeWidth, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,0,8,6"
                                   VerticalAlignment="Center"
                                   Text="投影宽度" />
                        <TextBox Height="28"
                                 Margin="0,0,0,6"
                                 Text="{Binding ProjectionWidth, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,0,8,6"
                                   VerticalAlignment="Center"
                                   Text="剔除比例" />
                        <TextBox Height="28"
                                 Margin="0,0,0,6"
                                 Text="{Binding RejectRatio, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,0,8,6"
                                   VerticalAlignment="Center"
                                   Text="剔除距离" />
                        <TextBox Height="28"
                                 Margin="0,0,0,6"
                                 Text="{Binding RejectDistance, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,0,8,6"
                                   VerticalAlignment="Center"
                                   Text="边缘极性" />
                        <ComboBox Height="28"
                                  Margin="0,0,0,6"
                                  SelectedValue="{Binding EdgePolarity, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="任意"
                                          Tag="{x:Static openCv:LineEdgePolarity.Any}" />
                            <ComboBoxItem Content="亮到暗"
                                          Tag="{x:Static openCv:LineEdgePolarity.Negative}" />
                            <ComboBoxItem Content="暗到亮"
                                          Tag="{x:Static openCv:LineEdgePolarity.Positive}" />
                        </ComboBox>

                        <TextBlock Margin="0,0,8,6"
                                   VerticalAlignment="Center"
                                   Text="候选选择" />
                        <ComboBox Height="28"
                                  Margin="0,0,0,6"
                                  SelectedValue="{Binding SelectionMode, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="最强"
                                          Tag="{x:Static openCv:LineSelectionMode.Strongest}" />
                            <ComboBoxItem Content="第一个"
                                          Tag="{x:Static openCv:LineSelectionMode.First}" />
                            <ComboBoxItem Content="最后一个"
                                          Tag="{x:Static openCv:LineSelectionMode.Last}" />
                        </ComboBox>

                        <TextBlock Margin="0,0,8,6"
                                   VerticalAlignment="Center"
                                   Text="扫描方向" />
                        <ComboBox Height="28"
                                  Margin="0,0,0,6"
                                  SelectedValue="{Binding ScanDirection, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="左到右"
                                          Tag="{x:Static openCv:LineScanDirection.LeftToRight}" />
                            <ComboBoxItem Content="右到左"
                                          Tag="{x:Static openCv:LineScanDirection.RightToLeft}" />
                            <ComboBoxItem Content="上到下"
                                          Tag="{x:Static openCv:LineScanDirection.TopToBottom}" />
                            <ComboBoxItem Content="下到上"
                                          Tag="{x:Static openCv:LineScanDirection.BottomToTop}" />
                        </ComboBox>
                    </UniformGrid>

                    <CheckBox Margin="0,4,0,0"
                              Content="显示搜索线"
                              IsChecked="{Binding ShowSearchLines}" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="SelectedBlockTemplate"
                      DataType="{x:Type models:FlowNode}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="38" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TabControl Grid.Row="0"
                            BorderThickness="0"
                            Background="#D5D7DA">
                    <TabItem Header="算子块属性"
                             IsSelected="True" />
                    <TabItem Header="资源" />
                </TabControl>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="5,10,5,5">
                        <Border Margin="0,0,0,8"
                                Padding="10"
                                Background="#FFFFFF"
                                BorderBrush="#D5DCE0"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Text="算子块名" />
                                <TextBox Grid.Column="1"
                                         Height="32"
                                         IsEnabled="{Binding IsConfigurable}"
                                         Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Border>

                        <Border Margin="0,0,0,8"
                                Padding="10"
                                Background="#FFFFFF"
                                BorderBrush="#D5DCE0"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Text="算子块备注" />
                                <TextBox Grid.Column="1"
                                         Height="32"
                                         IsEnabled="{Binding IsConfigurable}"
                                         Text="{Binding Remark, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Border>

                        <Border Margin="0,0,0,8"
                                Padding="10"
                                Background="#FFFFFF"
                                BorderBrush="#D5DCE0"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Text="启用块" />
                                <CheckBox Grid.Column="1"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          IsEnabled="{Binding IsConfigurable}"
                                          IsChecked="{Binding IsEnabled}" />
                            </Grid>
                        </Border>

                        <Border Margin="0,0,0,8"
                                Padding="10"
                                Background="#FFFFFF"
                                BorderBrush="#D5DCE0"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Text="图像窗口" />
                                <ComboBox Grid.Column="1"
                                          Height="32"
                                          IsEnabled="{Binding IsConfigurable}"
                                          SelectedValuePath="Content"
                                          SelectedValue="{Binding ImageWindowName}">
                                    <ComboBoxItem Content="图像窗口1" />
                                    <ComboBoxItem Content="图像窗口2" />
                                </ComboBox>
                            </Grid>
                        </Border>

                        <Border Padding="10"
                                Background="#FFFFFF"
                                BorderBrush="#D5DCE0"
                                BorderThickness="1"
                                CornerRadius="4"
                                IsEnabled="{Binding DataContext.CanEditVisionWorkflow, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                Visibility="{Binding DataContext.ShowOperatorPanel, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock FontSize="13"
                                           Text="算子列表" />

                                <WrapPanel Grid.Row="1"
                                           Margin="0,10,0,8">
                                    <Button Content="编辑"
                                            Style="{StaticResource ToolButtonStyle}" />
                                    <Button Content="运行"
                                            Style="{StaticResource ToolButtonStyle}" />
                                    <Button Content="断点"
                                            Style="{StaticResource ToolButtonStyle}" />
                                    <Button Content="禁用"
                                            Style="{StaticResource ToolButtonStyle}" />
                                    <Button Content="复制"
                                            Style="{StaticResource ToolButtonStyle}" />
                                    <Button Content="剪切"
                                            Style="{StaticResource ToolButtonStyle}" />
                                    <Button Content="粘贴"
                                            Style="{StaticResource ToolButtonStyle}" />
                                    <Button Content="删除"
                                            Style="{StaticResource ToolButtonStyle}" />
                                </WrapPanel>

                                <ListBox Grid.Row="2"
                                         AllowDrop="True"
                                         MinHeight="260"
                                         BorderBrush="#D5DCE0"
                                         BorderThickness="1"
                                         DragLeave="OperatorList_DragLeave"
                                         DragOver="OperatorList_DragOver"
                                         Drop="OperatorList_Drop"
                                         ItemsSource="{Binding Operators}"
                                         MouseDoubleClick="OperatorList_MouseDoubleClick"
                                         SelectedItem="{Binding SelectedOperator}">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="{x:Type ListBoxItem}">
                                            <Setter Property="HorizontalContentAlignment"
                                                    Value="Stretch" />
                                            <Setter Property="Padding"
                                                    Value="0" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:FlowOperator}">
                                            <Border MinHeight="70"
                                                    Padding="8,6"
                                                    BorderBrush="#E0E4E6"
                                                    BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="28" />
                                                        <ColumnDefinition Width="18" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="58" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock VerticalAlignment="Center"
                                                               Foreground="#222222"
                                                               Text="{Binding Sequence}" />
                                                    <Ellipse Grid.Column="1"
                                                             Width="11"
                                                             Height="11"
                                                             VerticalAlignment="Center">
                                                        <Ellipse.Style>
                                                            <Style TargetType="{x:Type Ellipse}">
                                                                <Setter Property="Fill"
                                                                        Value="#9AA3AD" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}"
                                                                                 Value="{x:Static models:FlowNodeStatus.Running}">
                                                                        <Setter Property="Fill"
                                                                                Value="#2D7DFF" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}"
                                                                                 Value="{x:Static models:FlowNodeStatus.OK}">
                                                                        <Setter Property="Fill"
                                                                                Value="#28CFA8" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}"
                                                                                 Value="{x:Static models:FlowNodeStatus.NG}">
                                                                        <Setter Property="Fill"
                                                                                Value="#D92B2B" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}"
                                                                                 Value="{x:Static models:FlowNodeStatus.Stopped}">
                                                                        <Setter Property="Fill"
                                                                                Value="#E5A400" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <StackPanel Grid.Column="2"
                                                                Margin="4,0,8,0">
                                                        <TextBlock FontSize="13"
                                                                   Text="{Binding DisplayName}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   FontSize="12"
                                                                   Foreground="#42526E"
                                                                   Text="{Binding LastMessage}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="3"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Center">
                                                        <Border MinWidth="40"
                                                                Padding="5,2"
                                                                CornerRadius="8">
                                                            <Border.Style>
                                                                <Style TargetType="{x:Type Border}">
                                                                    <Setter Property="Background"
                                                                            Value="#EEF1F3" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}"
                                                                                     Value="{x:Static models:FlowNodeStatus.Running}">
                                                                            <Setter Property="Background"
                                                                                    Value="#DDEBFF" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}"
                                                                                     Value="{x:Static models:FlowNodeStatus.OK}">
                                                                            <Setter Property="Background"
                                                                                    Value="#DCF8F0" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}"
                                                                                     Value="{x:Static models:FlowNodeStatus.NG}">
                                                                            <Setter Property="Background"
                                                                                    Value="#FFE3E3" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}"
                                                                                     Value="{x:Static models:FlowNodeStatus.Stopped}">
                                                                            <Setter Property="Background"
                                                                                    Value="#FFF2CC" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock HorizontalAlignment="Center"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Text="{Binding StatusText}" />
                                                        </Border>
                                                        <TextBlock Margin="0,4,0,0"
                                                                   HorizontalAlignment="Right"
                                                                   FontSize="11"
                                                                   Foreground="#6B778C"
                                                                   Text="{Binding ElapsedMilliseconds, StringFormat={}{0:0.0} ms}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <ContentControl Grid.Row="3"
                                                Content="{Binding SelectedOperator.Parameters}" />
                            </Grid>
                        </Border>

                        <Border Padding="10"
                                Background="#FFFFFF"
                                BorderBrush="#D5DCE0"
                                BorderThickness="1"
                                CornerRadius="4"
                                Visibility="{Binding DataContext.ShowGotoPanel, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock FontSize="13"
                                           Text="链接算子块" />
                                <ComboBox Grid.Row="1"
                                          Height="32"
                                          Margin="0,10,0,0"
                                          DisplayMemberPath="DisplayName"
                                          ItemsSource="{Binding DataContext.GotoTargetNodes, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                          SelectedValue="{Binding GotoTargetNodeId, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Id" />
                            </Grid>
                        </Border>

                        <Border Padding="10"
                                Background="#FFFFFF"
                                BorderBrush="#D5DCE0"
                                BorderThickness="1"
                                CornerRadius="4"
                                Visibility="{Binding DataContext.ShowBranchPanel, RelativeSource={RelativeSource AncestorType={x:Type Window}}, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DockPanel>
                                    <Ellipse Width="8"
                                             Height="8"
                                             Margin="0,0,18,0"
                                             Fill="#D92B2B" />
                                    <TextBlock VerticalAlignment="Center"
                                               Text="条件数据" />
                                </DockPanel>

                                <Grid Grid.Row="1"
                                      Margin="0,10,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="74" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Height="32"
                                             Text="{Binding ConditionDataName, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Content="添加数据源" />
                                </Grid>

                                <ListBox Grid.Row="2"
                                         MinHeight="280"
                                         BorderBrush="#D5DCE0"
                                         BorderThickness="1"
                                         ItemsSource="{Binding Branches}"
                                         SelectedItem="{Binding SelectedBranch}">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="{x:Type ListBoxItem}">
                                            <Setter Property="HorizontalContentAlignment"
                                                    Value="Stretch" />
                                            <Setter Property="Padding"
                                                    Value="0" />
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:FlowBranch}">
                                            <Grid Height="48">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding Sequence}" />
                                                <TextBox Grid.Column="1"
                                                         Margin="4,8"
                                                         Text="{Binding ConditionValue, UpdateSourceTrigger=PropertyChanged}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Grid Grid.Row="3"
                                      Margin="0,10,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Height="34"
                                            Command="{Binding DataContext.AddBranchCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                            Content="＋ 添加分支" />
                                    <Button Grid.Column="2"
                                            Height="34"
                                            Command="{Binding DataContext.RemoveBranchCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                            Content="删除分支" />
                                </Grid>

                                <Grid Grid.Row="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="44" />
                                        <RowDefinition Height="1" />
                                        <RowDefinition Height="44" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="1" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock VerticalAlignment="Center"
                                               Text="强制分支" />
                                    <CheckBox Grid.Column="2"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding ForceBranch}" />
                                    <Border Grid.Row="1"
                                            Grid.ColumnSpan="3"
                                            Background="#C9CED2" />
                                    <Border Grid.Column="1"
                                            Grid.RowSpan="3"
                                            Background="#C9CED2" />
                                    <TextBlock Grid.Row="2"
                                               Grid.ColumnSpan="2"
                                               VerticalAlignment="Center"
                                               Text="运行模式时强制功能失效" />
                                    <CheckBox Grid.Row="2"
                                              Grid.Column="2"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding ForceInvalidInRun}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,12"
                Padding="12"
                Background="#FFFFFF"
                BorderBrush="#DDE5E3"
                BorderThickness="1"
                CornerRadius="6">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#1E2C2A"
                               Text="流程图控件 Demo" />
                    <TextBlock Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="#687975"
                               Text="点击连线加号添加算子块，再把左侧算子拖入选中的算子块。" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="btnOpenImage"
                            Width="86"
                            Height="34"
                            Margin="0,0,8,0"
                            Click="btnOpenImage_Click"
                            Content="打开图像" />
                    <Button x:Name="btnStart"
                            Width="86"
                            Height="34"
                            Margin="0,0,8,0"
                            Click="btnStart_Click"
                            Content="启动"
                            IsEnabled="{Binding CanRunVision}" />
                    <Button x:Name="btnStop"
                            Width="86"
                            Height="34"
                            Click="btnStop_Click"
                            Content="停止"
                            IsEnabled="{Binding IsVisionRunning}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <controls:OperatorPaletteControl Grid.Column="0"
                                             IsEnabled="{Binding CanEditVisionWorkflow}" />
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" MinHeight="180" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource PanelCornerRadius}">
                    <controls:FlowChartControl x:Name="flowChart"
                                               CanEdit="{Binding CanEditVisionWorkflow}"
                                               Nodes="{Binding Nodes}"
                                               SelectedNode="{Binding SelectedNode, Mode=TwoWay}" />
                </Border>

                <GridSplitter Grid.Row="1"
                              Height="8"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Background="{StaticResource BorderBrush}"
                              ShowsPreview="True" />

                <Border Grid.Row="2"
                        Background="#111111"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource PanelCornerRadius}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="28" />
                        </Grid.RowDefinitions>
                        <wfi:WindowsFormsHost x:Name="ImageViewerHost" />
                        <Border Grid.Row="1"
                                Background="{StaticResource PanelAltBackgroundBrush}">
                            <TextBlock Margin="8,0"
                                       VerticalAlignment="Center"
                                       FontSize="{StaticResource StatusFontSize}"
                                       Foreground="#42526E"
                                       Text="{Binding VisionStatusText}" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="4"
                    Background="#F8F9FA"
                    BorderBrush="#D5DCE0"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ContentControl Content="{Binding SelectedNode}"
                                    IsEnabled="{Binding CanEditVisionWorkflow}"
                                    ContentTemplate="{StaticResource SelectedBlockTemplate}">
                        <ContentControl.Style>
                            <Style TargetType="{x:Type ContentControl}">
                                <Setter Property="Visibility"
                                        Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedNode}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility"
                                                Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>

                    <Border Grid.Row="1"
                            Margin="8"
                            Padding="10"
                            Background="{StaticResource PanelBackgroundBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource PanelCornerRadius}">
                        <StackPanel>
                            <TextBlock FontSize="{StaticResource SectionFontSize}"
                                       FontWeight="SemiBold"
                                       Foreground="#1E2C2A"
                                       Text="视觉结果" />
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="{StaticResource BodyFontSize}"
                                       Foreground="#42526E"
                                       Text="{Binding VisionRoiText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,6,0,0"
                                       FontSize="{StaticResource BodyFontSize}"
                                       Foreground="#42526E"
                                       Text="{Binding VisionResultText}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,10,0,0"
                                       FontSize="{StaticResource BodyFontSize}"
                                       FontWeight="SemiBold"
                                       Foreground="#1E2C2A"
                                       Text="运行日志" />
                            <ListBox MaxHeight="148"
                                     Margin="0,6,0,0"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     BorderThickness="1"
                                     ItemsSource="{Binding VisionRunLogs}"
                                     SelectedItem="{Binding SelectedVisionRunLog, Mode=TwoWay}">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="{x:Type ListBoxItem}">
                                        <Setter Property="HorizontalContentAlignment"
                                                Value="Stretch" />
                                        <Setter Property="Padding"
                                                Value="0" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type viewModels:VisionRunLogItem}">
                                        <Grid MinHeight="34"
                                              Margin="6,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="52" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock VerticalAlignment="Center"
                                                       FontSize="11"
                                                       Foreground="#6B778C"
                                                       Text="{Binding Sequence}" />
                                            <TextBlock Grid.Column="1"
                                                       FontSize="12"
                                                       Foreground="#1E2C2A"
                                                       Text="{Binding OperatorName}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Border Grid.Column="2"
                                                    MinWidth="40"
                                                    Padding="4,1"
                                                    CornerRadius="7">
                                                <Border.Style>
                                                    <Style TargetType="{x:Type Border}">
                                                        <Setter Property="Background"
                                                                Value="#EEF1F3" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}"
                                                                         Value="{x:Static models:FlowNodeStatus.Running}">
                                                                <Setter Property="Background"
                                                                        Value="#DDEBFF" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}"
                                                                         Value="{x:Static models:FlowNodeStatus.OK}">
                                                                <Setter Property="Background"
                                                                        Value="#DCF8F0" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}"
                                                                         Value="{x:Static models:FlowNodeStatus.NG}">
                                                                <Setter Property="Background"
                                                                        Value="#FFE3E3" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}"
                                                                         Value="{x:Static models:FlowNodeStatus.Stopped}">
                                                                <Setter Property="Background"
                                                                        Value="#FFF2CC" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding StatusText}" />
                                            </Border>
                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="1"
                                                       Grid.ColumnSpan="2"
                                                       Margin="0,2,0,0"
                                                       FontSize="11"
                                                       Foreground="#6B778C"
                                                       Text="{Binding ElapsedMilliseconds, StringFormat={}{0:0.0} ms}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
